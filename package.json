{
  "name": "wiki-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:services": "docker compose -f docker-compose.dev.yml up -d"
  }
}
